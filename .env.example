# Copy this file to .env and fill in real values.

SECRET_KEY=change-this-to-a-long-random-string
DEBUG=True
ALLOWED_HOSTS=localhost,127.0.0.1

# PostgreSQL connection string. Example:
# DATABASE_URL=postgres://username:password@localhost:5432/djchemboi
# Leave unset to fall back to local SQLite for quick testing.
DATABASE_URL=postgres://djchemboi_user:djchemboi_pass@localhost:5432/djchemboi

CORS_ALLOWED_ORIGINS=http://localhost:5173,http://127.0.0.1:5173

# Razorpay (placeholder) - get these from your Razorpay dashboard
RAZORPAY_KEY_ID=
RAZORPAY_KEY_SECRET=
